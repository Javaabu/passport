{
    "name": "javaabu/passport",
    "description": "laravel/passport with modifications",
    "homepage": "https://github.com/Javaabu/passport",
    "license": "MIT",
    "authors": [
        {
            "name": "Athfan Khaleel",
            "email": "athfan@javaabu.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.35 || ^12.0 || ^13.0",
        "laravel/passport": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.16 || ^10.8 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.5.3 || ^12.5.8 || ^13.0.3",
        "spatie/laravel-query-builder": "^6.3"
    },
    "autoload": {
        "psr-4": {
            "Javaabu\\Passport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Javaabu\\Passport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Javaabu\\Passport\\PassportServiceProvider"
            ],
            "dont-discover": [
                "laravel/passport"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
